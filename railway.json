{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "dockerfile",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "on-failure",
    "restartPolicyMaxRetries": 5,
    "startCommand": "npm start",
    "healthchecks": {
      "tcp": {
        "port": 3001
      }
    }
  },
  "plugins": [
    "postgresql"
  ]
}
