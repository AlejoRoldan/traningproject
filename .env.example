# ============================================================================
# NODE & ENVIRONMENT
# ============================================================================
NODE_ENV=development
PORT=3001
FRONTEND_PORT=3000
VITE_APP_ID=training-platform
VITE_APP_NAME=Contact Center Training Platform
VITE_APP_VERSION=1.0.0

# ============================================================================
# DATABASE - PostgreSQL
# ============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=training_user
DB_PASSWORD=training_password
DB_NAME=training_platform

# Connection strings (auto-generated from above if not set)
DATABASE_URL=postgresql://training_user:training_password@postgres:5432/training_platform
DB_SHADOW_DATABASE_URL=postgresql://training_user:training_password@postgres:5432/training_platform_shadow

# ============================================================================
# CACHE - Redis
# ============================================================================
REDIS_URL=redis://:redis_password@redis:6379/0
REDIS_PASSWORD=redis_password
REDIS_PORT=6379

# ============================================================================
# OPENAI API - GPT-4o, Whisper, TTS
# ============================================================================
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_ORGANIZATION_ID=org-...optional...
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096

# ============================================================================
# VOICE SYNTHESIS - ElevenLabs or VAPI
# ============================================================================
# Using ElevenLabs
ELEVENLABS_API_KEY=...your-key...
ELEVENLABS_VOICE_ID_MALE=default_male_voice_id
ELEVENLABS_VOICE_ID_FEMALE=default_female_voice_id

# Alternative: Using VAPI
VAPI_API_KEY=...your-key...
VAPI_PHONE_NUMBER=...your-phone...

# Which TTS provider to use: 'elevenlabs' | 'vapi' | 'openai'
TTS_PROVIDER=elevenlabs

# ============================================================================
# AWS S3 - Audio Storage
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=...your-access-key...
AWS_SECRET_ACCESS_KEY=...your-secret-key...
AWS_S3_BUCKET=training-platform-audio
AWS_S3_ENDPOINT=https://s3.amazonaws.com

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================
JWT_SECRET=...generate-strong-random-secret...
JWT_EXPIRATION=24h
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# OAuth Configuration
OAUTH_SERVER_URL=http://localhost:3001/oauth
OWNER_OPEN_ID=...owner-id...
OWNER_NAME=...owner-name...

# Built-in Forge API
BUILT_IN_FORGE_API_URL=http://localhost:3001/api/forge
BUILT_IN_FORGE_API_KEY=...api-key...

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json
# Supported: 'debug', 'info', 'warn', 'error'

# ============================================================================
# EMAIL (Optional - for notifications)
# ============================================================================
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=test@example.com
SMTP_PASSWORD=
SMTP_FROM=noreply@training-platform.local

# ============================================================================
# ANALYTICS & MONITORING
# ============================================================================
# Frontend Analytics
VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_ENDPOINT=http://localhost:3001/api/analytics
VITE_ANALYTICS_WEBSITE_ID=kaitel-training-platform
VITE_ANALYTICS_TRACK_USERS=true
VITE_ANALYTICS_DEBUG=false

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
# Slack notifications (optional)
SLACK_WEBHOOK_URL=

# Sentry error tracking (optional)
SENTRY_DSN=

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_VOICE_ANALYSIS=true
FEATURE_GAMIFICATION=true
FEATURE_REAL_TIME_EVALUATION=true
FEATURE_MULTIPLE_LANGUAGES=false

# ============================================================================
# PERFORMANCE
# ============================================================================
MAX_AUDIO_FILE_SIZE=52428800  # 50MB in bytes
AUDIO_PROCESSING_TIMEOUT=30000  # 30 seconds
EVALUATION_TIMEOUT=60000  # 60 seconds
WEBSOCKET_PING_INTERVAL=25000
WEBSOCKET_PING_TIMEOUT=60000

# ============================================================================
# DATABASE ADMINISTRATION (Development)
# ============================================================================
PGADMIN_EMAIL=admin@training-platform.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ============================================================================
# SEED DATA (Development)
# ============================================================================
SEED_DEMO_USER=true
SEED_SCENARIOS=true
SEED_ACHIEVEMENTS=true
