# ============================================================================
# NODE & ENVIRONMENT
# ============================================================================
NODE_ENV=production
PORT=3001

# ============================================================================
# DATABASE - PostgreSQL (Railways lo proporciona automáticamente)
# ============================================================================
# Nota: En Railways, agregar PostgreSQL auto-genera DATABASE_URL
# Si no aparece, copiar desde la pestaña "Variables" del servicio PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/training_db

# ============================================================================
# OPENAI API - GPT-4, Whisper, TTS
# ============================================================================
# ⚠️ NOTA: Configurar OPENAI_API_KEY en Railways directamente (NO en Git)
OPENAI_API_KEY=placeholder-configure-in-railway
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096

# ============================================================================
# AWS S3 - Audio Storage (Mock para desarrollo)
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=mock-dev-key
AWS_SECRET_ACCESS_KEY=mock-dev-secret
AWS_S3_BUCKET=training-platform-audio-dev

# ============================================================================
# VOICE SYNTHESIS - ElevenLabs (Mock para desarrollo)
# ============================================================================
ELEVENLABS_API_KEY=mock-dev-key
ELEVENLABS_VOICE_ID_MALE=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ID_FEMALE=EXAVITQu4vr4xnSDxMaL
TTS_PROVIDER=elevenlabs

# ============================================================================
# SECURITY
# ============================================================================
JWT_SECRET=e183359b0444f6a652fb6a07feef3fef4976ccf97728a0d5957e5a390d5978c2
JWT_EXPIRATION=24h
CORS_ORIGIN=*

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_VOICE_ANALYSIS=true
FEATURE_GAMIFICATION=true
FEATURE_REAL_TIME_EVALUATION=true
FEATURE_MULTIPLE_LANGUAGES=false

# ============================================================================
# PERFORMANCE
# ============================================================================
MAX_AUDIO_FILE_SIZE=52428800
AUDIO_PROCESSING_TIMEOUT=30000
EVALUATION_TIMEOUT=60000
WEBSOCKET_PING_INTERVAL=30000
WEBSOCKET_PING_TIMEOUT=60000
